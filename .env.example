# Admin bearer token (for creating API keys via the REST API)
ADMIN_BEARER_TOKEN=changeme123

# Transcription settings
MAX_AUDIO_SIZE_MB=256

# Whisper model settings
WHISPER_MODEL=distil-large-v3
WHISPER_COMPUTE_TYPE=float16

# Max seconds before a transcription job is marked failed
JOB_TIMEOUT_SECONDS=3600

# ---------------------------------------------------------------------------
# Pull-worker (optional)
# Set WEB_URL to enable pull-worker mode. When set, blurb_manager will
# automatically start web_worker.py alongside the blurb server.
# ---------------------------------------------------------------------------

# Base URL for the remote API. Blurb appends /worker/jobs/next, /worker/audio/{id}, etc.
# e.g. https://palpal.app/api
WEB_URL=

# Shared API key for remote authentication (must match BLURB_API_KEY on the server)
BLURB_API_KEY=

# Seconds to wait between polls when no job is available (default: 5)
POLL_INTERVAL=5
